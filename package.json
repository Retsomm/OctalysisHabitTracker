{
  "name": "octalysis-habit-tracker",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "backend",
      "frontend"
    ],
    "nohoist": [
      "**/vite",
      "**/vite/**",
      "**/@vitejs/plugin-react",
      "**/@vitejs/plugin-react/**",
      "**/@tailwindcss/vite",
      "**/@tailwindcss/vite/**"
    ]
  },
  "scripts": {
    "dev": "concurrently -k -n BE,FE -c cyan,green \"yarn workspace octalysis-backend dev\" \"yarn workspace frontend dev\"",
    "db:migrate": "yarn workspace octalysis-backend db:migrate",
    "db:generate": "yarn workspace octalysis-backend db:generate",
    "db:studio": "yarn workspace octalysis-backend db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "resolutions": {
    "vite": "^7.3.1"
  }
}